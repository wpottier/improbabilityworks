---
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from './BaseLayout.astro';
import { t, htmlLang, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  /** Canonical slug key — must match a SLUG_MAP entry. */
  slug: 'legal' | 'eula' | 'privacy';
  /** From MDX frontmatter — already locale-specific. */
  title: string;
  description: string;
  /** Date object from z.coerce.date() — already parsed by Zod. */
  lastUpdated: Date;
}

const { locale, slug, title, description, lastUpdated } = Astro.props;

const lastUpdatedDate = new Intl.DateTimeFormat(htmlLang(locale), {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(lastUpdated);
---
<BaseLayout
  locale={locale}
  slug={slug}
  title={`${title} — Improbability Works`}
  description={description}
  cosmic={true}
>
  <article class="container-editorial py-20 md:py-28 legal-prose">

    <nav aria-label="breadcrumb" class="text-xs font-mono uppercase tracking-[0.22em] text-silver-cool/50 mb-6">
      <a href={getRelativeLocaleUrl(locale, '')} class="hover:text-parchment">{t('legal.layout.breadcrumbHome', locale)}</a>
      <span aria-hidden="true" class="mx-2">/</span>
      <span>{title}</span>
    </nav>

    <header class="max-w-3xl">
      <h1 class="font-display text-4xl md:text-5xl text-parchment leading-tight">{title}</h1>
      <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.24em] text-gold-warm">
        {t('legal.layout.lastUpdated', locale)} · {lastUpdatedDate}
      </p>
    </header>

    <div class="mt-12 max-w-3xl">
      <slot />
    </div>

    <p class="mt-16 text-xs text-silver-cool/50">
      <a href={getRelativeLocaleUrl(locale, '')} class="underline underline-offset-2 hover:text-parchment">
        ← {t('legal.layout.backHome', locale)}
      </a>
    </p>

  </article>
</BaseLayout>

<style is:global>
  .legal-prose h2 {
    font-family: theme('fontFamily.display');
    font-size: 1.5rem;
    margin-top: 2.5rem;
    color: var(--parchment);
    scroll-margin-top: 5rem;
  }
  .legal-prose h3 {
    font-family: theme('fontFamily.display');
    font-size: 1.1rem;
    margin-top: 1.75rem;
    color: var(--parchment);
  }
  .legal-prose p, .legal-prose li {
    color: rgba(201, 205, 214, 0.85);
    line-height: 1.75;
    font-size: 0.975rem;
  }
  .legal-prose p { margin-top: 0.9rem; }
  .legal-prose ul, .legal-prose ol {
    margin-top: 0.75rem;
    padding-left: 1.25rem;
  }
  .legal-prose ul  { list-style: disc; }
  .legal-prose ol  { list-style: decimal; }
  .legal-prose li + li { margin-top: 0.35rem; }
  .legal-prose a {
    color: var(--gold-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .legal-prose a:hover { color: var(--parchment); }
  .legal-prose strong  { color: var(--parchment); }
  .legal-prose em      { color: var(--silver-cool); }
  .legal-prose hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid rgba(212, 175, 106, 0.2);
  }
  /* Section component styles */
  .legal-prose section { margin-top: 0.5rem; }
  .legal-prose .section-num {
    font-family: theme('fontFamily.mono');
    color: var(--gold-warm);
    font-size: 0.85em;
    margin-right: 0.6rem;
  }
</style>
