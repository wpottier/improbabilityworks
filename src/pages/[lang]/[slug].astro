---
/**
 * Non-default locale legal pages.
 * EN legal pages live at src/pages/[slug].astro (root, no prefix).
 * This file handles every other locale — currently only FR.
 */
import { getCollection, render } from 'astro:content';
import LegalLayout from '../../layouts/LegalLayout.astro';
import Section from '../../components/mdx/Section.astro';
import { DEFAULT_LOCALE, type Locale } from '../../i18n/utils';

export async function getStaticPaths() {
  // Exclude default locale — its legal pages are at root via src/pages/[slug].astro.
  const entries = await getCollection('legal', ({ data }) => data.locale !== DEFAULT_LOCALE);
  return entries.map((entry) => ({
    params: { lang: entry.data.locale, slug: entry.data.urlSlug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const locale = entry.data.locale as Locale;
---

<LegalLayout
  locale={locale}
  slug={entry.data.canonical}
  title={entry.data.title}
  description={entry.data.description}
  lastUpdated={entry.data.lastUpdated}
>
  <Content components={{ Section }} />
</LegalLayout>
