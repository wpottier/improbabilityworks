---
import { getRelativeLocaleUrl } from 'astro:i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, type Locale, SLUG_MAP } from '../i18n/utils';

interface Props {
  locale: Locale;
  slug: string;
}
const { locale, slug } = Astro.props;

const home = getRelativeLocaleUrl(locale, '');

// Legal pages use locale-specific slugs — SLUG_MAP remains the source of truth.
const legalUrl  = getRelativeLocaleUrl(locale, SLUG_MAP.legal[locale]);
const eulaUrl   = getRelativeLocaleUrl(locale, SLUG_MAP.eula[locale]);
const privacyUrl = getRelativeLocaleUrl(locale, SLUG_MAP.privacy[locale]);

const year = new Date().getFullYear();
const copyright = t('footer.copyright', locale).replace('{year}', String(year));
---
<footer class="relative mt-32 border-t border-white/5 bg-ink-deep/80">
  <div class="container-wide py-16">
    <div class="grid gap-12 md:grid-cols-[2fr_1fr_1fr_1fr_1fr]">

      <!-- Brand -->
      <div>
        <a href={home} class="inline-flex items-center gap-3" aria-label="Improbability Works">
          <svg viewBox="0 0 32 32" class="w-7 h-7 text-gold-warm" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
            <path d="M16 3 L27 9 V23 L16 29 L5 23 V9 Z" />
            <circle cx="16" cy="16" r="5" />
          </svg>
          <span class="flex flex-col leading-none">
            <span class="font-display text-base text-parchment">Improbability</span>
            <span class="font-deco text-[10px] tracking-[0.28em] text-gold-warm">WORKS</span>
          </span>
        </a>
        <p class="mt-5 max-w-sm text-sm text-silver-cool/70 text-pretty">{t('footer.tagline', locale)}</p>
      </div>

      <div>
        <h3 class="eyebrow">{t('footer.colStudio', locale)}</h3>
        <ul class="mt-4 space-y-2 text-sm text-silver-cool/80">
          <li><a class="hover:text-parchment" href={`${home}#manifesto`}>{t('footer.links.manifesto', locale)}</a></li>
          <li><a class="hover:text-parchment" href={`${home}#team`}>{t('footer.links.team', locale)}</a></li>
          <li><a class="hover:text-parchment" href={`${home}#dispatch`}>{t('footer.links.newsletter', locale)}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="eyebrow">{t('footer.colGame', locale)}</h3>
        <ul class="mt-4 space-y-2 text-sm text-silver-cool/80">
          <li><a class="hover:text-parchment" href={`${home}#velvet-door`}>{t('footer.links.velvetDoor', locale)}</a></li>
          {/* TODO: replace STEAM_APP_ID with real Velvet Door Steam app id. */}
          <li>
            <a class="hover:text-parchment" href="https://store.steampowered.com/app/STEAM_APP_ID/Velvet_Door/" rel="noopener" target="_blank">
              {t('footer.links.wishlist', locale)} ↗
            </a>
          </li>
          <li><a class="hover:text-parchment" href="#press-kit">{t('footer.links.pressKit', locale)}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="eyebrow">{t('footer.colLegal', locale)}</h3>
        <ul class="mt-4 space-y-2 text-sm text-silver-cool/80">
          <li><a class="hover:text-parchment" href={legalUrl}>{t('footer.links.legalNotice', locale)}</a></li>
          <li><a class="hover:text-parchment" href={eulaUrl}>{t('footer.links.eula', locale)}</a></li>
          <li><a class="hover:text-parchment" href={privacyUrl}>{t('footer.links.privacy', locale)}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="eyebrow">{t('footer.colSocial', locale)}</h3>
        <ul class="mt-4 space-y-2 text-sm text-silver-cool/80">
          {/* TODO: replace # with real Discord, Bluesky, Mastodon, GitHub URLs. */}
          <li><a class="hover:text-parchment" href="#" rel="me">{t('footer.links.discord', locale)}</a></li>
          <li><a class="hover:text-parchment" href="#" rel="me">{t('footer.links.bluesky', locale)}</a></li>
          <li><a class="hover:text-parchment" href="#" rel="me">{t('footer.links.mastodon', locale)}</a></li>
          <li><a class="hover:text-parchment" href="#" rel="me">{t('footer.links.github', locale)}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col md:flex-row md:items-center md:justify-between gap-4 pt-6 border-t border-white/5">
      <p class="text-xs text-silver-cool/50 font-mono tracking-wider">{copyright}</p>
      <div class="flex items-center gap-6">
        <span class="text-xs text-silver-cool/50 italic">{t('footer.madeIn', locale)}</span>
        <LanguageSwitcher locale={locale} slug={slug} variant="footer" />
      </div>
    </div>
  </div>
</footer>
