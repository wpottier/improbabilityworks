---
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Pre-compute particle positions at build time so we ship zero JS for them.
// Deterministic seeded pseudo-random → same layout per build, no hydration mismatch.
function seeded(n: number) {
  const x = Math.sin(n * 9301 + 49297) * 233280;
  return x - Math.floor(x);
}
const particles = Array.from({ length: 38 }, (_, i) => {
  const top = Math.round(seeded(i + 1) * 100);
  const left = Math.round(seeded(i + 11) * 100);
  const size = 1 + Math.round(seeded(i + 21) * 2); // 1..3
  const durKind = i % 3; // 0 slow, 1 mid, 2 fast
  const delay = (seeded(i + 31) * 9).toFixed(2);
  const shine = seeded(i + 41) > 0.85;
  return { top, left, size, durKind, delay, shine };
});
---
<section
  class="relative isolate overflow-hidden grain-overlay"
  aria-labelledby="hero-title"
>
  <!-- Layered backgrounds -->
  <div class="absolute inset-0 pointer-events-none -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-[linear-gradient(180deg,#050814_0%,#070B1C_60%,#0B0E26_100%)]"></div>
    <!-- Portal halo, positioned right-center, breathes slowly -->
    <div class="absolute right-[-6%] top-[22%] h-[620px] w-[620px] max-w-[70vw] max-h-[70vw] rounded-full bg-hero-portal blur-[6px] motion-safe:animate-portal-breathe"></div>
    <!-- Faint concentric portal ring, decorative -->
    <svg
      class="absolute right-[2%] top-[28%] h-[460px] w-[460px] max-w-[55vw] max-h-[55vw] opacity-70 motion-safe:animate-portal-breathe"
      viewBox="0 0 460 460"
      fill="none"
    >
      <defs>
        <radialGradient id="portalCore" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#8FD0FF" stop-opacity="0.5" />
          <stop offset="40%" stop-color="#6B3FD4" stop-opacity="0.25" />
          <stop offset="100%" stop-color="#2B4DDB" stop-opacity="0" />
        </radialGradient>
      </defs>
      <circle cx="230" cy="230" r="160" stroke="#D4AF6A" stroke-opacity="0.18" stroke-width="0.8" />
      <circle cx="230" cy="230" r="120" stroke="#D4AF6A" stroke-opacity="0.22" stroke-width="0.8" />
      <circle cx="230" cy="230" r="80" stroke="#F5D98E" stroke-opacity="0.32" stroke-width="0.8" />
      <circle cx="230" cy="230" r="110" fill="url(#portalCore)" />
    </svg>
  </div>

  <!-- Starfield particles (CSS-only) -->
  <div class="absolute inset-0 pointer-events-none -z-10 opacity-90" aria-hidden="true">
    {particles.map((p) => (
      <span
        class:list={[
          'absolute rounded-full',
          p.shine ? 'bg-gold-bright' : 'bg-gold-warm/70',
          p.durKind === 0 ? 'motion-safe:animate-twinkle-slow' : p.durKind === 1 ? 'motion-safe:animate-twinkle-mid' : 'motion-safe:animate-twinkle-fast',
        ]}
        style={`top:${p.top}%;left:${p.left}%;width:${p.size}px;height:${p.size}px;animation-delay:${p.delay}s;${p.shine ? 'box-shadow:0 0 6px rgba(245,217,142,0.9);' : ''}`}
      ></span>
    ))}
  </div>

  <div class="container-wide relative pt-20 pb-28 md:pt-32 md:pb-40">
    <div class="grid grid-cols-12 gap-6 items-center">
      <div class="col-span-12 lg:col-span-9">
        <p class="eyebrow reveal">{t('hero.eyebrow', locale)}</p>

        <h1
          id="hero-title"
          class="headline-monument mt-5 text-balance reveal"
          style="--reveal-delay: 80ms;"
        >
          {t('hero.title', locale)}
        </h1>

        <div class="mt-8 flex gap-5 items-start max-w-2xl reveal" style="--reveal-delay: 200ms;">
          <span class="rule-gold mt-3 shrink-0" aria-hidden="true"></span>
          <p class="font-display italic text-xl md:text-2xl text-parchment/90 leading-snug text-balance">
            {t('hero.tagline', locale)}
          </p>
        </div>

        <p class="mt-8 max-w-xl text-base md:text-lg text-silver-cool/80 leading-relaxed text-pretty reveal" style="--reveal-delay: 320ms;">
          {t('hero.body', locale)}
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 reveal" style="--reveal-delay: 440ms;">
          <a href="#velvet-door" class="btn btn-primary group">
            <span>{t('hero.ctaPrimary', locale)}</span>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover:translate-y-0.5">
              <path d="M8 3V13M3 8L8 13L13 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a href="https://discord.gg/QBmZu3ds" rel="noopener" target="_blank" class="btn btn-outline">
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.54 5.34a16.96 16.96 0 0 0-4.2-1.3.06.06 0 0 0-.07.03c-.18.33-.38.75-.52 1.09a15.66 15.66 0 0 0-4.7 0 10.78 10.78 0 0 0-.53-1.09.06.06 0 0 0-.07-.03 16.9 16.9 0 0 0-4.2 1.3.05.05 0 0 0-.03.02C2.41 9.37 1.78 13.3 2.09 17.17a.07.07 0 0 0 .03.05 17.1 17.1 0 0 0 5.15 2.6.06.06 0 0 0 .07-.02c.4-.54.76-1.12 1.06-1.72a.06.06 0 0 0-.03-.08 11.27 11.27 0 0 1-1.62-.77.06.06 0 0 1 0-.1c.11-.08.22-.17.32-.26a.06.06 0 0 1 .06-.01c3.4 1.55 7.06 1.55 10.41 0a.06.06 0 0 1 .07.01c.1.1.21.18.33.27.05.04.04.09 0 .1a10.6 10.6 0 0 1-1.63.77.06.06 0 0 0-.03.08c.31.6.67 1.18 1.06 1.72a.06.06 0 0 0 .07.02 17.05 17.05 0 0 0 5.16-2.6.06.06 0 0 0 .03-.05c.37-4.48-.62-8.38-2.63-11.8a.05.05 0 0 0-.03-.03ZM8.52 14.82c-1.03 0-1.88-.94-1.88-2.1s.83-2.1 1.88-2.1c1.06 0 1.9.95 1.88 2.1 0 1.16-.83 2.1-1.88 2.1Zm6.98 0c-1.03 0-1.88-.94-1.88-2.1s.83-2.1 1.88-2.1c1.06 0 1.9.95 1.88 2.1 0 1.16-.82 2.1-1.88 2.1Z" />
            </svg>
            <span>{t('hero.ctaSecondary', locale)}</span>
          </a>
        </div>
      </div>

      <!-- Right-side decorative portal ornament on large screens (redundant with bg halo but adds weight) -->
      <div class="hidden lg:block lg:col-span-3 relative" aria-hidden="true">
        <svg viewBox="0 0 240 320" class="w-full h-auto text-gold-warm/40" fill="none">
          <path d="M40 260 V 120 C 40 70 80 30 120 30 C 160 30 200 70 200 120 V 260" stroke="currentColor" stroke-width="0.8" />
          <path d="M52 260 V 124 C 52 82 82 46 120 46 C 158 46 188 82 188 124 V 260" stroke="currentColor" stroke-opacity="0.55" stroke-width="0.6" />
          <line x1="40" y1="260" x2="200" y2="260" stroke="currentColor" stroke-width="0.8" />
          <line x1="60" y1="270" x2="180" y2="270" stroke="currentColor" stroke-opacity="0.5" stroke-width="0.6" />
          <circle cx="120" cy="140" r="2" fill="#F5D98E" />
        </svg>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="mt-16 flex items-center gap-3 reveal" style="--reveal-delay: 600ms;">
      <span class="font-mono uppercase text-[10px] tracking-[0.3em] text-silver-cool/45">{t('hero.scrollCue', locale)}</span>
      <svg class="motion-safe:animate-scroll-cue" width="10" height="14" viewBox="0 0 10 14" fill="none" aria-hidden="true">
        <path d="M5 1 V 12 M1 8 L 5 12 L 9 8" stroke="#D4AF6A" stroke-opacity="0.65" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </div>
</section>
