---
import { getRelativeLocaleUrl } from 'astro:i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  slug: string;
}
const { locale, slug } = Astro.props;

const home = getRelativeLocaleUrl(locale, '');

const navLinks = [
  { href: `${home}#manifesto`, label: t('nav.manifesto', locale) },
  { href: `${home}#velvet-door`, label: t('nav.game', locale) },
  { href: `${home}#roadmap`, label: t('nav.roadmap', locale) },
  { href: `${home}#team`, label: t('nav.team', locale) },
  // Newsletter hidden until provider is configured.
  // { href: `${home}#dispatch`, label: t('nav.newsletter', locale) },
];
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-ink-deep/70 border-b border-white/5">
  <div class="container-wide flex items-center justify-between py-4">
    <a href={home} class="flex items-center gap-3 group" aria-label="Improbability Works — home">
      <span class="relative inline-block w-8 h-8" aria-hidden="true">
        <span class="absolute inset-0 rounded-full bg-gradient-to-br from-portal-violet to-portal-blue blur-md opacity-60 group-hover:opacity-80 transition"></span>
        <svg viewBox="0 0 32 32" class="relative w-8 h-8 text-gold-warm" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M16 3 L27 9 V23 L16 29 L5 23 V9 Z" />
          <circle cx="16" cy="16" r="5" />
          <path d="M16 11 C19 13 19 19 16 21 C13 19 13 13 16 11 Z" fill="currentColor" opacity="0.4" />
        </svg>
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-display text-base tracking-tight text-parchment">Improbability</span>
        <span class="font-deco text-[10px] tracking-[0.28em] text-gold-warm">WORKS</span>
      </span>
    </a>

    <nav aria-label={t('nav.ariaLabel', locale)} class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-sans text-[13px] tracking-wide text-silver-cool/80 hover:text-parchment transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-5">
      <LanguageSwitcher locale={locale} slug={slug} variant="nav" />
    </div>
  </div>
</header>
