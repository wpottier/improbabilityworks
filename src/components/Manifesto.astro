---
import { getDict, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const d = getDict(locale).manifesto;
---
<section id="manifesto" aria-labelledby="manifesto-title" class="relative py-28 md:py-36">
  <div class="container-editorial">
    <header class="max-w-3xl">
      <p class="eyebrow reveal">{d.eyebrow}</p>
      <h2 id="manifesto-title" class="font-display text-4xl md:text-6xl leading-[1.05] text-balance text-parchment mt-6 reveal" style="--reveal-delay: 80ms;">
        {d.title}
      </h2>
      <p class="mt-6 max-w-xl text-silver-cool/75 text-pretty reveal" style="--reveal-delay: 160ms;">{d.intro}</p>
    </header>

    <ol class="mt-20 space-y-20 md:space-y-28" role="list">
      {d.pillars.map((p, i) => {
        const isOdd = i % 2 === 1;
        return (
          <li class="relative reveal" style={`--reveal-delay: ${80 * i}ms;`}>
            <div class={`grid grid-cols-12 gap-6 items-start ${isOdd ? 'md:[&>*:first-child]:col-start-3' : ''}`}>
              <div class="col-span-3 md:col-span-2">
                <span class="font-display text-6xl md:text-7xl text-gold-warm/60 leading-none tabular-nums">
                  {p.number}
                </span>
              </div>
              <div class="col-span-9 md:col-span-8">
                <h3 class="font-display text-2xl md:text-3xl text-parchment leading-snug text-balance">
                  {p.title}
                </h3>
                <p class="mt-4 text-silver-cool/80 text-lg leading-relaxed max-w-xl text-pretty">
                  {p.body}
                </p>
              </div>
            </div>
            {i < d.pillars.length - 1 && (
              <div class="mt-16 md:mt-20 ml-0 md:ml-[16%] w-24 h-px bg-gradient-to-r from-gold-warm/40 to-transparent" aria-hidden="true"></div>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</section>
