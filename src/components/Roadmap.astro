---
import { SOCIAL_LINKS } from '../config/social';
import { getDict, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const d = getDict(locale).roadmap;
---
<section id="roadmap" aria-labelledby="roadmap-title" class="relative py-28 md:py-36">
  <div class="container-editorial">
    <header class="max-w-3xl">
      <p class="eyebrow reveal">{d.eyebrow}</p>
      <h2 id="roadmap-title" class="font-display text-4xl md:text-6xl leading-[1.05] text-parchment mt-6 text-balance reveal" style="--reveal-delay: 80ms;">
        {d.title}
      </h2>
      <p class="mt-6 text-silver-cool/75 max-w-xl reveal" style="--reveal-delay: 160ms;">{d.intro}</p>
    </header>

    <ol class="mt-20 relative" role="list">
      <!-- Timeline spine -->
      <div class="absolute left-[14px] md:left-[24px] top-2 bottom-2 w-px bg-gradient-to-b from-gold-warm/50 via-portal-violet/30 to-transparent" aria-hidden="true"></div>

      {d.stages.map((s, i) => (
        <li class="relative pl-12 md:pl-20 pb-14 last:pb-0 reveal" style={`--reveal-delay: ${80 * i}ms;`}>
          <span
            class="absolute left-0 md:left-[10px] top-1 w-[30px] h-[30px] rounded-full flex items-center justify-center bg-ink-night border border-gold-warm/50"
            aria-hidden="true"
          >
            <span class="w-2 h-2 rounded-full bg-gold-bright shadow-[0_0_10px_rgba(245,217,142,0.8)]"></span>
          </span>
          <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-gold-warm">{s.label}</p>
          <h3 class="font-display text-2xl md:text-3xl text-parchment mt-2 leading-snug">{s.title}</h3>
          <p class="mt-3 text-silver-cool/75 max-w-xl text-pretty">{s.body}</p>
        </li>
      ))}
    </ol>

    <div class="mt-12 reveal">
      <a href={SOCIAL_LINKS.discord} rel="noopener" target="_blank" class="btn btn-outline">
        <span>{d.ctaDiscord}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
